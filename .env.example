# ── Способ 1: готовая строка соединения целиком ─────────────────────────────
# ONEC_CONNECTION_STRING=File="C:\bases\acc";Usr="Администратор";Pwd="pass"

# ── Способ 2: по частям ─────────────────────────────────────────────────────
# Файловая база:
ONEC_FILE=C:\bases\acc
# Серверная база (вместо ONEC_FILE):
# ONEC_SRVR=server-1c
# ONEC_REF=accounting

# Аутентификация (для обоих способов):
ONEC_USR=Администратор
ONEC_PWD=

# ProgID COM-коннектора (по умолчанию V83.COMConnector):
# ONEC_COMCONNECTOR=V83.COMConnector

# Путь к обработке-исполнителю для execute_script
# (по умолчанию executor\mcpИсполнитель.epf рядом с сервером):
# ONEC_EXECUTOR_EPF=D:\Documents\разработка_1С\mcp-1c-com\executor\mcpИсполнитель.epf
